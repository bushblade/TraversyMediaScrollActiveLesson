{
  "manifest_version": 3,
  "name": "Traversy Media - Official Extension",
  "version": "1.3.0",
  "description": "Improves the UX of the Traversy Media course platform",
  "icons": {
    "48": "logo-48.jpg"
  },
  "content_scripts": [
    {
      "matches": ["*://*.traversymedia.com/products/*"],
      "js": ["index.js", "videoSettings.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["wistia-injector.js"],
      "matches": ["*://*.traversymedia.com/*"]
    }
  ],
  "action": {
    "default_icon": "logo-48.jpg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "traversy-media@willadams.dev",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
